		<script is:inline>
			(function () {
				var KEY = 'varmonitor-lang';
				var btnEn = document.querySelector('[data-lang-btn="en"]');
				var btnEs = document.querySelector('[data-lang-btn="es"]');
				var pageEn = document.querySelector('.page-lang--en');
				var pageEs = document.querySelector('.page-lang--es');

				function setActiveButton(lang) {
					if (!btnEn || !btnEs) return;
					var enOn = lang === 'en';
					btnEn.classList.toggle('text-cyan-400', enOn);
					btnEn.classList.toggle('text-slate-500', !enOn);
					btnEs.classList.toggle('text-cyan-400', !enOn);
					btnEs.classList.toggle('text-slate-500', enOn);
				}

				function show(lang) {
					if (!pageEn || !pageEs) return;
					var isEn = lang === 'en';
					pageEn.classList.toggle('hidden', !isEn);
					pageEs.classList.toggle('hidden', isEn);
					document.documentElement.lang = isEn ? 'en' : 'es';
					setActiveButton(lang);
					document.querySelectorAll('[data-i18n-header="en"]').forEach(function (el) {
						el.classList.toggle('hidden', !isEn);
					});
					document.querySelectorAll('[data-i18n-header="es"]').forEach(function (el) {
						el.classList.toggle('hidden', isEn);
					});
					var mk = document.querySelector('[data-mkdocs-link]');
					if (mk) {
						mk.href = isEn ? 'docs/en/' : 'docs/es/';
						mk.setAttribute(
							'aria-label',
							isEn ? 'MkDocs technical documentation (English)' : 'Documentación técnica MkDocs (español)',
						);
					}
					try {
						localStorage.setItem(KEY, lang);
					} catch (e) {}
				}

				if (btnEn) btnEn.addEventListener('click', function () { show('en'); });
				if (btnEs) btnEs.addEventListener('click', function () { show('es'); });

				var initial = 'en';
				try {
					initial = localStorage.getItem(KEY) || 'en';
				} catch (e) {}
				show(initial === 'es' ? 'es' : 'en');
			})();
		</script>
