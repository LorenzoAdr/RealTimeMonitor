---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
/** Enlace relativo: funciona en dev (/) y en Pages de proyecto (/RealTimeMonitor/). */
const docsHrefEn = 'docs/en/';
const docsHrefEs = 'docs/es/';

/** Orden: posición i·60° desde las 12 en punto; radio --orbit-r en la sección ecosistema */
const ecosystemRadialEn = [
	{
		title: '3D flight visualization',
		body: 'Spatial flight-path and attitude views for telemetry-driven 3D scenes.',
		svgPath:
			'M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 5l-2-1-2 1M4 5l2-1M4 5l2 1M4 5v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5',
	},
	{
		title: 'Simulated PFD & joystick',
		body: 'Synthetic primary flight display and joystick input for desktop HIL-style workflows.',
		svgPath:
			'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
	},
	{
		title: 'Automatic documentation',
		body: 'Generated docs from your project metadata—keep manuals in sync with the codebase.',
		svgPath:
			'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
	},
	{
		title: 'Remote IDE & debug',
		body: 'Browser-based IDE surface with attach-to-process debugging over your stack.',
		svgPath: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
	},
	{
		title: 'Git remote management',
		body: 'Repository operations from the monitor—branches, remotes, and review flows without leaving the UI.',
		svgPath: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
	},
	{
		title: 'ARINC 429 & MIL-STD-1553',
		bodyHtml:
			'Real-time word decode and <strong class="text-slate-300">health detection</strong>—parity faults, bad SSM, and more—backed by an easy-to-manage <strong class="text-slate-300">SQLite</strong> label registry.',
		svgPath:
			'M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0',
	},
];

const ecosystemRadialEs = [
	{
		title: 'Visualización 3D de vuelo',
		body: 'Vistas espaciales de trayectoria y actitud alimentadas por telemetría.',
		svgPath:
			'M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 5l-2-1-2 1M4 5l2-1M4 5l2 1M4 5v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5',
	},
	{
		title: 'PFD simulada y joystick',
		body: 'Display primario de vuelo sintético y entrada joystick para flujos tipo HIL en escritorio.',
		svgPath:
			'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
	},
	{
		title: 'Documentación automática',
		body: 'Generación de manuales a partir de metadatos del proyecto, alineados con el código.',
		svgPath:
			'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
	},
	{
		title: 'IDE remoto y depuración',
		body: 'Superficie IDE en el navegador con capacidad de depuración sobre tu pila.',
		svgPath: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
	},
	{
		title: 'Gestión remota de Git',
		body: 'Operaciones de repositorio desde el monitor: ramas, remotos y flujos de revisión sin salir de la UI.',
		svgPath: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
	},
	{
		title: 'ARINC 429 y MIL-STD-1553',
		bodyHtml:
			'Decodificación en tiempo real y <strong class="text-slate-300">detección de salud</strong> (paridad, SSM erróneo, etc.) sobre un registro <strong class="text-slate-300">SQLite</strong> fácil de mantener.',
		svgPath:
			'M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0',
	},
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="VarMonitor — ultra-low-latency telemetry for critical systems. C++, shared memory, real-time web monitor."
		/>
		<meta name="keywords" content="VarMonitor, telemetry, C++, shared memory, SHM, low latency, engineering" />
		<meta name="theme-color" content="#020617" />
		<title>VarMonitor — Real-time telemetry</title>
	</head>
	<body class="min-h-dvh bg-slate-950 text-slate-300 antialiased selection:bg-cyan-500/20 selection:text-cyan-100">
		<header
			class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-md"
		>
			<div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-6 lg:px-8">
				<a
					href="#top"
					class="font-mono text-sm font-semibold tracking-tight text-white transition hover:text-cyan-400"
				>
					VarMonitor
				</a>
				<div class="flex items-center gap-2 sm:gap-3 md:gap-4">
					<a
						data-mkdocs-link
						href={docsHrefEn}
						class="group flex max-w-[11rem] items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-2.5 py-2 text-xs font-medium text-slate-200 transition hover:border-cyan-500/35 hover:bg-cyan-500/10 hover:text-cyan-200 sm:max-w-none sm:px-3 sm:text-sm"
					>
						<svg class="h-4 w-4 shrink-0 text-slate-400 transition group-hover:text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
						</svg>
						<span data-i18n-header="en" class="leading-tight">Technical information</span>
						<span data-i18n-header="es" class="hidden leading-tight">Información técnica</span>
					</a>
					<div class="flex items-center rounded-lg border border-white/10 bg-white/5 p-0.5 font-mono text-xs font-medium">
						<button
							type="button"
							data-lang-btn="en"
							class="rounded-md px-2.5 py-1.5 text-cyan-400 transition hover:text-cyan-300"
						>
							EN
						</button>
						<button
							type="button"
							data-lang-btn="es"
							class="rounded-md px-2.5 py-1.5 text-slate-500 transition hover:text-slate-400"
						>
							ES
						</button>
					</div>
					<a
						href="https://github.com/LorenzoAdr/RealTimeMonitor"
						target="_blank"
						rel="noopener noreferrer"
						class="group flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-500/40 hover:bg-cyan-500/10 hover:text-cyan-300"
						aria-label="GitHub repository"
					>
						<svg class="h-5 w-5 text-slate-400 transition group-hover:text-cyan-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
						</svg>
						<span class="hidden sm:inline">GitHub</span>
					</a>
				</div>
			</div>
		</header>

		<div id="top" class="sr-only" aria-hidden="true"></div>

		<!-- English (default) -->
		<div class="page-lang page-lang--en">
			<main>
				<section class="relative overflow-hidden px-6 pb-24 pt-20 lg:px-8 lg:pb-32 lg:pt-28">
					<div class="pointer-events-none absolute inset-0 -z-10">
						<div class="absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-cyan-500/10 blur-[120px]" />
						<div class="absolute bottom-0 right-0 h-64 w-64 rounded-full bg-cyan-600/5 blur-3xl" />
					</div>

					<div class="mx-auto max-w-4xl text-center">
						<div
							class="mb-8 inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 px-4 py-1.5 font-mono text-xs font-medium uppercase tracking-widest text-cyan-400/90"
						>
							<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-cyan-400" />
							C++ High-Performance Telemetry
						</div>

						<h1
							class="bg-gradient-to-b from-white to-slate-500 bg-clip-text text-4xl font-semibold tracking-tight text-transparent sm:text-5xl md:text-6xl lg:text-7xl lg:leading-[1.05]"
						>
							VarMonitor: Visualize performance. In real time.
						</h1>

						<p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-slate-400 md:text-xl">
							Ultra-low-latency <span class="text-slate-300">telemetry framework</span> for critical systems—from the C++
							core to the web monitor without giving up determinism or observability.
						</p>

						<div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
							<a
								href="https://github.com/LorenzoAdr/RealTimeMonitor"
								target="_blank"
								rel="noopener noreferrer"
								class="group inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-8 py-4 text-base font-semibold text-slate-950 shadow-lg shadow-cyan-500/25 transition hover:bg-cyan-400 hover:shadow-cyan-400/30"
							>
								Get started
								<svg class="h-5 w-5 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
								</svg>
							</a>
							<a
								href="#arquitectura-core-en"
								class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-8 py-4 text-base font-semibold text-white transition hover:border-cyan-500/40 hover:bg-white/[0.07]"
							>
								View architecture
							</a>
						</div>
					</div>
				</section>

				<section
					id="arquitectura-core-en"
					class="border-t border-white/5 bg-slate-950 py-24 lg:py-32"
				>
					<div class="mx-auto max-w-6xl px-6 lg:px-8">
						<h2 class="text-center font-mono text-sm font-medium uppercase tracking-widest text-cyan-400/80">
							Native pipeline
						</h2>
						<p class="mx-auto mt-4 max-w-3xl text-center text-3xl font-semibold tracking-tight text-white md:text-4xl">
							Native performance. Zero blocking.
						</p>

						<div class="mt-20 grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-x-12 xl:gap-x-16">
							<div class="flex w-full justify-center lg:justify-start lg:pl-0">
								<div class="w-full max-w-xl lg:-translate-x-10 xl:-translate-x-14 2xl:-translate-x-16">
								<div
									class="rounded-2xl border border-white/10 bg-slate-900/50 p-6 shadow-2xl shadow-black/40 backdrop-blur-sm sm:p-8"
									aria-hidden="true"
								>
									<div class="flex flex-col items-center gap-3 md:hidden">
										<div class="w-full max-w-xs rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-5 text-center">
											<p class="font-mono text-xs font-medium uppercase tracking-wider text-cyan-300">C++ Producer</p>
										</div>
										<div class="flex flex-col items-center py-1">
											<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">sem</span>
											<svg class="h-8 w-6 text-cyan-500/70" fill="none" viewBox="0 0 24 40" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v24m0 0l-6-6m6 6l6-6" />
											</svg>
										</div>
										<div
											class="w-full max-w-xs rounded-xl border-2 border-dashed border-cyan-400/40 bg-gradient-to-br from-cyan-500/10 to-slate-900 px-4 py-8 text-center"
										>
											<p class="font-mono text-xs font-bold uppercase tracking-widest text-cyan-400">Shared Memory</p>
											<p class="mt-1 font-mono text-lg font-semibold text-white">SHM</p>
											<p class="mt-2 text-xs text-slate-500">POSIX</p>
										</div>
										<div class="flex flex-col items-center py-1">
											<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">snapshot</span>
											<svg class="h-8 w-6 text-cyan-500/70" fill="none" viewBox="0 0 24 40" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v24m0 0l-6-6m6 6l6-6" />
											</svg>
										</div>
										<div class="w-full max-w-xs rounded-lg border border-violet-500/30 bg-violet-500/10 px-4 py-5 text-center">
											<p class="font-mono text-xs font-medium uppercase tracking-wider text-violet-300">Python consumer</p>
											<p class="mt-1 font-mono text-[10px] text-slate-500">FastAPI · WS</p>
										</div>
									</div>
									<div class="hidden items-center justify-between gap-4 md:flex">
										<div class="flex-1 rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-8 text-center">
											<p class="font-mono text-xs font-medium uppercase tracking-wider text-cyan-300">Producer</p>
											<p class="mt-1 text-sm font-semibold text-white">C++</p>
										</div>
										<div class="flex flex-col items-center gap-1">
											<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">uds + sem</span>
											<svg class="h-6 w-14 shrink-0 text-cyan-500/70" fill="none" viewBox="0 0 56 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h40m0 0l-7-7m7 7l-7 7" />
											</svg>
										</div>
										<div
											class="w-[200px] shrink-0 rounded-xl border-2 border-dashed border-cyan-400/40 bg-gradient-to-br from-cyan-500/10 to-slate-900 px-3 py-10 text-center shadow-inner"
										>
											<p class="font-mono text-xs font-bold uppercase tracking-widest text-cyan-400">Shared Memory</p>
											<p class="mt-1 font-mono text-lg font-semibold text-white">SHM</p>
											<p class="mt-2 text-xs text-slate-500">snapshot</p>
										</div>
										<div class="flex flex-col items-center gap-1">
											<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">read</span>
											<svg class="h-6 w-14 shrink-0 text-cyan-500/70" fill="none" viewBox="0 0 56 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h40m0 0l-7-7m7 7l-7 7" />
											</svg>
										</div>
										<div class="flex-1 rounded-lg border border-violet-500/30 bg-violet-500/10 px-4 py-8 text-center md:translate-x-2 lg:translate-x-3">
											<p class="font-mono text-xs font-medium uppercase tracking-wider text-violet-300">Consumer</p>
											<p class="mt-1 text-sm font-semibold text-white">Python</p>
											<p class="font-mono text-[10px] text-slate-500">FastAPI · WS</p>
										</div>
									</div>
								</div>
								</div>
							</div>

							<ul class="flex flex-col gap-2">
								<li
									class="group rounded-xl border border-transparent px-2 py-2 transition hover:border-cyan-500/20 hover:bg-slate-900/50 focus-within:border-cyan-500/25 focus-within:bg-slate-900/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/40"
									tabindex="0"
								>
									<div class="flex gap-3">
										<div
											class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 transition group-hover:border-cyan-400/40 group-hover:bg-cyan-500/15"
										>
											<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
											</svg>
										</div>
										<div class="min-w-0 flex-1">
											<h3 class="text-base font-semibold leading-snug text-white">SHM zero-copy</h3>
											<div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out group-hover:grid-rows-[1fr] group-focus-within:grid-rows-[1fr]">
												<div class="min-h-0 overflow-hidden">
													<p class="pt-2 text-sm leading-relaxed text-slate-400">
														Data lives in a shared segment: the producer writes snapshots and the consumer reads without
														unnecessary copies across processes.
													</p>
												</div>
											</div>
										</div>
									</div>
								</li>
								<li
									class="group rounded-xl border border-transparent px-2 py-2 transition hover:border-cyan-500/20 hover:bg-slate-900/50 focus-within:border-cyan-500/25 focus-within:bg-slate-900/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/40"
									tabindex="0"
								>
									<div class="flex gap-3">
										<div
											class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 transition group-hover:border-cyan-400/40 group-hover:bg-cyan-500/15"
										>
											<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
											</svg>
										</div>
										<div class="min-w-0 flex-1">
											<h3 class="text-base font-semibold leading-snug text-white">C++ lock-free</h3>
											<div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out group-hover:grid-rows-[1fr] group-focus-within:grid-rows-[1fr]">
												<div class="min-h-0 overflow-hidden">
													<p class="pt-2 text-sm leading-relaxed text-slate-400">
														Modern synchronization and atomic structures where it matters, cutting contention on the hot
														path.
													</p>
												</div>
											</div>
										</div>
									</div>
								</li>
								<li
									class="group rounded-xl border border-transparent px-2 py-2 transition hover:border-cyan-500/20 hover:bg-slate-900/50 focus-within:border-cyan-500/25 focus-within:bg-slate-900/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cyan-500/40"
									tabindex="0"
								>
									<div class="flex gap-3">
										<div
											class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 transition group-hover:border-cyan-400/40 group-hover:bg-cyan-500/15"
										>
											<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
												<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
											</svg>
										</div>
