---
import '../styles/global.css';

const base = import.meta.env.BASE_URL;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="VarMonitor — telemetría de ultra-baja latencia para sistemas críticos. C++20, memoria compartida, monitor web en tiempo real."
		/>
		<meta name="keywords" content="VarMonitor, telemetría, C++20, shared memory, SHM, baja latencia, ingeniería" />
		<meta name="theme-color" content="#020617" />
		<title>VarMonitor — Telemetría en tiempo real</title>
	</head>
	<body class="min-h-dvh bg-slate-950 text-slate-300 antialiased selection:bg-cyan-500/20 selection:text-cyan-100">
		<!-- Header -->
		<header
			class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-md"
		>
			<div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 lg:px-8">
				<a
					href="#top"
					class="font-mono text-sm font-semibold tracking-tight text-white transition hover:text-cyan-400"
				>
					VarMonitor
				</a>
				<a
					href="https://github.com/LorenzoAdr/RealTimeMonitor"
					target="_blank"
					rel="noopener noreferrer"
					class="group flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-500/40 hover:bg-cyan-500/10 hover:text-cyan-300"
					aria-label="Repositorio en GitHub"
				>
					<svg class="h-5 w-5 text-slate-400 transition group-hover:text-cyan-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
					</svg>
					<span class="hidden sm:inline">GitHub</span>
				</a>
			</div>
		</header>

		<main id="top">
			<!-- Hero -->
			<section class="relative overflow-hidden px-6 pb-24 pt-20 lg:px-8 lg:pb-32 lg:pt-28">
				<div class="pointer-events-none absolute inset-0 -z-10">
					<div class="absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-cyan-500/10 blur-[120px]" />
					<div class="absolute bottom-0 right-0 h-64 w-64 rounded-full bg-cyan-600/5 blur-3xl" />
				</div>

				<div class="mx-auto max-w-4xl text-center">
					<div
						class="mb-8 inline-flex items-center gap-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 px-4 py-1.5 font-mono text-xs font-medium uppercase tracking-widest text-cyan-400/90"
					>
						<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-cyan-400" />
						C++20 High-Performance Telemetry
					</div>

					<h1
						class="bg-gradient-to-b from-white to-slate-500 bg-clip-text text-4xl font-semibold tracking-tight text-transparent sm:text-5xl md:text-6xl lg:text-7xl lg:leading-[1.05]"
					>
						VarMonitor: Visualiza el rendimiento. En tiempo real.
					</h1>

					<p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-slate-400 md:text-xl">
						Framework de telemetría de <span class="text-slate-300">ultra-baja latencia</span> para sistemas
						críticos: del núcleo C++ al monitor web sin sacrificar determinismo ni visibilidad.
					</p>

					<div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
						<a
							href="https://github.com/LorenzoAdr/RealTimeMonitor"
							target="_blank"
							rel="noopener noreferrer"
							class="group inline-flex items-center gap-2 rounded-xl bg-cyan-500 px-8 py-4 text-base font-semibold text-slate-950 shadow-lg shadow-cyan-500/25 transition hover:bg-cyan-400 hover:shadow-cyan-400/30"
						>
							Empezar
							<svg class="h-5 w-5 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
							</svg>
						</a>
						<a
							href="#arquitectura-core"
							class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-8 py-4 text-base font-semibold text-white transition hover:border-cyan-500/40 hover:bg-white/[0.07]"
						>
							Ver Arquitectura
						</a>
					</div>
				</div>
			</section>

			<!-- Sección 1: Core & SHM -->
			<section
				id="arquitectura-core"
				class="border-t border-white/5 bg-slate-950 py-24 lg:py-32"
			>
				<div class="mx-auto max-w-6xl px-6 lg:px-8">
					<h2 class="text-center font-mono text-sm font-medium uppercase tracking-widest text-cyan-400/80">
						Pipeline nativo
					</h2>
					<p class="mx-auto mt-4 max-w-3xl text-center text-3xl font-semibold tracking-tight text-white md:text-4xl">
						Rendimiento Nativo. Cero Bloqueos.
					</p>

					<div class="mt-20 grid gap-16 lg:grid-cols-2 lg:items-center lg:gap-20">
						<!-- Diagrama técnico -->
						<div
							class="rounded-2xl border border-white/10 bg-slate-900/50 p-6 shadow-2xl shadow-black/40 backdrop-blur-sm sm:p-8"
							aria-hidden="true"
						>
							<!-- Móvil: flujo vertical -->
							<div class="flex flex-col items-center gap-3 md:hidden">
								<div class="w-full max-w-xs rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-5 text-center">
									<p class="font-mono text-xs font-medium uppercase tracking-wider text-cyan-300">Productor C++</p>
								</div>
								<div class="flex flex-col items-center py-1">
									<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">sem</span>
									<svg class="h-8 w-6 text-cyan-500/70" fill="none" viewBox="0 0 24 40" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v24m0 0l-6-6m6 6l6-6" />
									</svg>
								</div>
								<div
									class="w-full max-w-xs rounded-xl border-2 border-dashed border-cyan-400/40 bg-gradient-to-br from-cyan-500/10 to-slate-900 px-4 py-8 text-center"
								>
									<p class="font-mono text-xs font-bold uppercase tracking-widest text-cyan-400">Shared Memory</p>
									<p class="mt-1 font-mono text-lg font-semibold text-white">SHM</p>
									<p class="mt-2 text-xs text-slate-500">POSIX</p>
								</div>
								<div class="flex flex-col items-center py-1">
									<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">snapshot</span>
									<svg class="h-8 w-6 text-cyan-500/70" fill="none" viewBox="0 0 24 40" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v24m0 0l-6-6m6 6l6-6" />
									</svg>
								</div>
								<div class="w-full max-w-xs rounded-lg border border-violet-500/30 bg-violet-500/10 px-4 py-5 text-center">
									<p class="font-mono text-xs font-medium uppercase tracking-wider text-violet-300">Consumidor Python</p>
									<p class="mt-1 font-mono text-[10px] text-slate-500">FastAPI · WS</p>
								</div>
							</div>
							<!-- Desktop: flujo horizontal -->
							<div class="hidden items-center justify-between gap-4 md:flex">
								<div class="flex-1 rounded-lg border border-cyan-500/30 bg-cyan-500/10 px-4 py-8 text-center">
									<p class="font-mono text-xs font-medium uppercase tracking-wider text-cyan-300">Productor</p>
									<p class="mt-1 text-sm font-semibold text-white">C++</p>
								</div>
								<div class="flex flex-col items-center gap-1">
									<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">uds + sem</span>
									<svg class="h-6 w-14 shrink-0 text-cyan-500/70" fill="none" viewBox="0 0 56 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h40m0 0l-7-7m7 7l-7 7" />
									</svg>
								</div>
								<div
									class="w-[200px] shrink-0 rounded-xl border-2 border-dashed border-cyan-400/40 bg-gradient-to-br from-cyan-500/10 to-slate-900 px-3 py-10 text-center shadow-inner"
								>
									<p class="font-mono text-xs font-bold uppercase tracking-widest text-cyan-400">Shared Memory</p>
									<p class="mt-1 font-mono text-lg font-semibold text-white">SHM</p>
									<p class="mt-2 text-xs text-slate-500">snapshot</p>
								</div>
								<div class="flex flex-col items-center gap-1">
									<span class="font-mono text-[10px] uppercase tracking-widest text-slate-500">lectura</span>
									<svg class="h-6 w-14 shrink-0 text-cyan-500/70" fill="none" viewBox="0 0 56 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 12h40m0 0l-7-7m7 7l-7 7" />
									</svg>
								</div>
								<div class="flex-1 rounded-lg border border-violet-500/30 bg-violet-500/10 px-4 py-8 text-center">
									<p class="font-mono text-xs font-medium uppercase tracking-wider text-violet-300">Consumidor</p>
									<p class="mt-1 text-sm font-semibold text-white">Python</p>
									<p class="font-mono text-[10px] text-slate-500">FastAPI · WS</p>
								</div>
							</div>
						</div>

						<!-- Bullets -->
						<ul class="flex flex-col gap-10">
							<li class="group flex gap-5">
								<div
									class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 transition group-hover:border-cyan-400/40 group-hover:bg-cyan-500/15"
								>
									<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
									</svg>
								</div>
								<div>
									<h3 class="text-lg font-semibold text-white">SHM Zero-Copy</h3>
									<p class="mt-1 leading-relaxed text-slate-400">
										Los datos viven en un segmento compartido: el productor escribe snapshots y el consumidor lee
										sin copias innecesarias entre procesos.
									</p>
								</div>
							</li>
							<li class="group flex gap-5">
								<div
									class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 transition group-hover:border-cyan-400/40 group-hover:bg-cyan-500/15"
								>
									<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
									</svg>
								</div>
								<div>
									<h3 class="text-lg font-semibold text-white">C++20 Lock-Free</h3>
									<p class="mt-1 leading-relaxed text-slate-400">
										Sincronización con primitivas modernas y estructuras atómicas donde aplica, reduciendo contención
										en el camino crítico.
									</p>
								</div>
							</li>
							<li class="group flex gap-5">
								<div
									class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl border border-cyan-500/20 bg-cyan-500/10 text-cyan-400 transition group-hover:border-cyan-400/40 group-hover:bg-cyan-500/15"
								>
									<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
									</svg>
								</div>
								<div>
									<h3 class="text-lg font-semibold text-white">Latencia &lt; 1 ms</h3>
									<p class="mt-1 leading-relaxed text-slate-400">
										Diseñado para ciclos de publicación agresivos y visualización en el navegador al ritmo que exige
										tu banco de pruebas.
									</p>
								</div>
							</li>
						</ul>
					</div>
				</div>
			</section>

			<!-- Sección 2: Ecosistema -->
			<section class="border-t border-white/5 bg-slate-900 py-24 lg:py-32">
				<div class="mx-auto max-w-6xl px-6 lg:px-8">
					<div class="mx-auto max-w-2xl text-center">
						<h2 class="font-mono text-sm font-medium uppercase tracking-widest text-cyan-400/80">
							Extensibilidad
						</h2>
						<p class="mt-4 text-3xl font-semibold tracking-tight text-white md:text-4xl">
							Un ecosistema modular a tu medida.
						</p>
						<p class="mt-4 text-slate-400">
							Plugins y backends opcionales para encajar VarMonitor en tu cadena de herramientas.
						</p>
					</div>

					<div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
						<article
							class="group rounded-2xl border border-white/5 bg-slate-950/80 p-6 shadow-lg transition hover:-translate-y-1 hover:border-cyan-500/25 hover:shadow-cyan-500/5"
						>
							<div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400 transition group-hover:bg-cyan-500/20">
								<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
								</svg>
							</div>
							<h3 class="font-semibold text-white">Motor Parquet</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-400">
								Persistencia <strong class="text-slate-300">Parquet</strong> para logs estructurados de alto
								rendimiento y análisis offline.
							</p>
						</article>

						<article
							class="group rounded-2xl border border-white/5 bg-slate-950/80 p-6 shadow-lg transition hover:-translate-y-1 hover:border-cyan-500/25 hover:shadow-cyan-500/5"
						>
							<div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400 transition group-hover:bg-cyan-500/20">
								<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
								</svg>
							</div>
							<h3 class="font-semibold text-white">Replay Engine</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-400">
								Reproducción de capturas y escenarios offline para validar regresiones sin el hardware en bucle.
							</p>
						</article>

						<article
							class="group rounded-2xl border border-white/5 bg-slate-950/80 p-6 shadow-lg transition hover:-translate-y-1 hover:border-cyan-500/25 hover:shadow-cyan-500/5"
						>
							<div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400 transition group-hover:bg-cyan-500/20">
								<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
								</svg>
							</div>
							<h3 class="font-semibold text-white">OPC UA / PLC Connect</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-400">
								Hoja de ruta hacia integración industrial y SCADA: conectores dedicados para planta.
							</p>
						</article>

						<article
							class="group rounded-2xl border border-white/5 bg-slate-950/80 p-6 shadow-lg transition hover:-translate-y-1 hover:border-cyan-500/25 hover:shadow-cyan-500/5"
						>
							<div class="mb-4 flex h-11 w-11 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400 transition group-hover:bg-cyan-500/20">
								<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
								</svg>
							</div>
							<h3 class="font-semibold text-white">Auditoría SHA-256</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-400">
								Trazabilidad criptográfica e integración con flujos <strong class="text-slate-300">RAG</strong> para
								informes forenses reproducibles y certificables.
							</p>
						</article>
					</div>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="border-t border-white/5 bg-slate-950 py-12">
			<div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 text-center text-sm text-slate-500 md:flex-row md:text-left lg:px-8">
				<p>
					© {new Date().getFullYear()} VarMonitor · Código y documentación bajo{' '}
					<a
						href="https://github.com/LorenzoAdr/RealTimeMonitor/blob/main/LICENSE"
						class="text-cyan-500/90 underline decoration-cyan-500/30 underline-offset-2 transition hover:text-cyan-400"
					>
						licencia MIT
					</a>
					.
				</p>
				<p>
					<a
						href="https://github.com/LorenzoAdr"
						target="_blank"
						rel="noopener noreferrer"
						class="font-mono text-slate-400 transition hover:text-cyan-400"
					>
						@LorenzoAdr
					</a>
					<span class="mx-2 text-slate-700">·</span>
					<a
						href="https://github.com/LorenzoAdr/RealTimeMonitor"
						target="_blank"
						rel="noopener noreferrer"
						class="transition hover:text-cyan-400"
					>
						Repositorio
					</a>
				</p>
			</div>
		</footer>
	</body>
</html>
