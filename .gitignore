node_modules/
build/
__pycache__/
*.pyc
.venv/
.venv-build/
web_monitor/dist/
# JS minificado generado por scripts/varmon/build_web_static_js.sh (opcional en repo)
web_monitor/static/
*.so
*.o
*.a
.env

# Copias locales de lanzadores antiguos (no subir al despliegue)
scripts/_legacy_launch/

# Runtime artifacts generated by web monitor
web_monitor/recordings/
web_monitor/recordings/*.tsv
web_monitor/recordings/alarm_*.tsv
web_monitor/recordings/record_*.tsv
web_monitor/recordings/snapshot_*.tsv
web_monitor/recordings/segment_*.tsv

# Backend state generated by UI actions (templates/sessions)
web_monitor/server_state/
web_monitor/server_state/templates/
web_monitor/server_state/sessions/

# MkDocs build output
# PDF de documentación generado localmente
dist-docs/
# MkDocs copiado al sitio Astro (scripts/build_docs_for_astro.sh); regenerar antes de build/preview
astro/public/docs/es/
astro/public/docs/en/

# Datos bajo data/ (config data/varmon.conf sí se versiona)
data/recordings/
data/server_state/

# SQLite WAL/SHM locales (no versionar)
web_monitor/arinc_data/*.sqlite-shm
web_monitor/arinc_data/*.sqlite-wal

# Capturas / previews locales del agente
artifacts/

# Paquete de entrega local y dirs de build de prueba
web_monitor_version/
# Copias de seguridad locales del paquete de entrega (no versionar)
web_monitor_version_old/
build-judge/
build-plan-verify/
build-sidecar/

# Wheels de plugins copiadas localmente (tool_plugins/scripts/copy_to_mit.sh)
web_monitor/vendor/
web_monitor/dist/

# Generado por apply-plugin-selection.mjs (no versionar; build_all lo recrea)
tool_plugins

